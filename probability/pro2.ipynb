   "source": [
    "import sympy as sp\n",
    "n,k=sp.symbols('n,k')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "3c40b928",
   "metadata": {},
   "outputs": [],
   "source": [
    "expr=1/n*sp.Sum(k**2,(k,1,n))"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "282732df",
   "metadata": {},
   "outputs": [
    {
     "data": {
      "text/latex": [
       "$\\displaystyle \\frac{2 n^{2} + 3 n + 1}{6}$"
      ],
      "text/plain": [
       "(2*n**2 + 3*n + 1)/6"
      ]
     },
     "execution_count": 8,
     "metadata": {},
     "output_type": "execute_result"
    }
   ],
   "source": [
    "sp.together(sp.cancel(expr.doit()))"
   ]
  }
